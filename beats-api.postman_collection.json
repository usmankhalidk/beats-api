            "url": {
              "raw": "{{baseUrl}}/user/profile/avatar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "profile",
                "avatar"
              ]
            },
            "description": "Upload a profile avatar via multipart/form-data. Field name must be \"avatar\". Returns updated profile with new avatar URL."
          },
          "response": []
        }
      ]
    },
