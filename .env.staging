NODE_ENV=staging
PORT=4000
APP_NAME=beats-api
APP_URL=https://staging.example.com

DATABASE_URL="mysql://user:password@staging-db:3306/beats_staging"

JWT_ACCESS_SECRET=replace-in-secret-manager
JWT_REFRESH_SECRET=replace-in-secret-manager
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PASSWORD_RESET_TOKEN_TTL_MINUTES=30

CORS_ORIGINS=https://staging-web.example.com

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

LOG_LEVEL=info
