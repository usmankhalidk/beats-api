generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                                           BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  firstname                                    String?                @db.VarChar(50)
  lastname                                     String?                @db.VarChar(50)
  username                                     String?                @unique(map: "users_username_unique") @db.VarChar(50)
  email                                        String?                @unique(map: "users_email_unique") @db.VarChar(100)
  address                                      String?                @db.Text
  password                                     String?                @db.VarChar(255)
  api_key                                      String?                @db.VarChar(255)
  is_author                                    Boolean                @default(false)
  is_featured_author                           Boolean                @default(false)
  balance                                      Float                  @default(0)
  level_id                                     BigInt?                @db.UnsignedBigInt
  exclusivity                                  users_exclusivity?
  total_sales                                  BigInt                 @default(0) @db.UnsignedBigInt
  total_sales_amount                           Float?                 @default(0)
  total_referrals_earnings                     Float?                 @default(0)
  total_reviews                                BigInt                 @default(0) @db.UnsignedBigInt
  avg_reviews                                  BigInt                 @default(0) @db.UnsignedBigInt
  total_followers                              BigInt                 @default(0) @db.UnsignedBigInt
  total_following                              BigInt                 @default(0) @db.UnsignedBigInt
  avatar                                       String?                @db.VarChar(255)
  profile_cover                                String?                @db.VarChar(255)
  profile_heading                              String?                @db.VarChar(255)
  profile_description                          String?                @db.LongText
  profile_contact_email                        String?                @db.VarChar(255)
  profile_social_links                         String?                @db.Text
  facebook_id                                  String?                @unique(map: "users_facebook_id_unique") @db.VarChar(255)
  google_id                                    String?                @unique(map: "users_google_id_unique") @db.VarChar(255)
  microsoft_id                                 String?                @unique(map: "microsoft_id") @db.VarChar(255)
  vkontakte_id                                 String?                @unique(map: "vkontakte_id") @db.VarChar(255)
  envato_id                                    String?                @unique(map: "envato_id") @db.VarChar(255)
  github_id                                    String?                @unique(map: "github_id") @db.VarChar(255)
  withdrawal_method_id                         BigInt?                @db.UnsignedBigInt
  withdrawal_account                           String?                @db.Text
  was_subscribed                               Boolean                @default(false)
  email_verified_at                            DateTime?              @db.Timestamp(0)
  kyc_status                                   Boolean                @default(false)
  google2fa_status                             Boolean                @default(false)
  google2fa_secret                             String?                @db.Text
  status                                       Boolean                @default(true)
  remember_token                               String?                @db.VarChar(100)
  createdAt                                    DateTime?              @map("created_at") @db.Timestamp(0)
  updatedAt                                    DateTime?              @updatedAt @map("updated_at") @db.Timestamp(0)
  blog_comments                                blog_comments[]
  cartItems                                    CartItem[]
  favorites                                    favorites[]
  followers_followers_follower_idTousers       followers[]            @relation("followers_follower_idTousers")
  followers_followers_following_idTousers      followers[]            @relation("followers_following_idTousers")
  item_comment_replies                         item_comment_replies[]
  item_comment_reports                         item_comment_reports[]
  item_comments_item_comments_author_idTousers item_comments[]        @relation("item_comments_author_idTousers")
  item_comments_item_comments_user_idTousers   item_comments[]        @relation("item_comments_user_idTousers")
  item_histories                               item_histories[]
  item_review_replies                          item_review_replies[]
  item_reviews_item_reviews_author_idTousers   item_reviews[]         @relation("item_reviews_author_idTousers")
  item_reviews_item_reviews_user_idTousers     item_reviews[]         @relation("item_reviews_user_idTousers")
  item_updates                                 item_updates[]
  items                                        items[]
  kyc_verifications                            kyc_verifications[]
  premium_earnings                             premium_earnings[]
  purchases_purchases_author_idTousers         purchases[]            @relation("purchases_author_idTousers")
  purchases_purchases_user_idTousers           purchases[]            @relation("purchases_user_idTousers")
  referral_earnings                            referral_earnings[]
  referrals_referrals_author_idTousers         referrals[]            @relation("referrals_author_idTousers")
  referrals_referrals_user_idTousers           referrals[]            @relation("referrals_user_idTousers")
  refund_replies                               refund_replies[]
  refunds_refunds_author_idTousers             refunds[]              @relation("refunds_author_idTousers")
  refunds_refunds_user_idTousers               refunds[]              @relation("refunds_user_idTousers")
  sales_sales_author_idTousers                 sales[]                @relation("sales_author_idTousers")
  sales_sales_user_idTousers                   sales[]                @relation("sales_user_idTousers")
  statements                                   statements[]
  subscriptions                                subscriptions[]
  support_earnings                             support_earnings[]
  ticket_replies                               ticket_replies[]
  tickets                                      tickets[]
  transactions                                 transactions[]
  uploaded_files                               uploaded_files[]
  user_badges                                  user_badges[]
  user_login_logs                              user_login_logs[]
  levels                                       levels?                @relation(fields: [level_id], references: [id], onUpdate: Restrict, map: "users_level_id_foreign")
  withdrawal_methods                           withdrawal_methods?    @relation(fields: [withdrawal_method_id], references: [id], onUpdate: Restrict, map: "users_withdrawal_method_id_foreign")
  withdrawals                                  withdrawals[]

  @@index([level_id], map: "users_level_id_foreign")
  @@index([withdrawal_method_id], map: "users_withdrawal_method_id_foreign")
  @@map("users")
}

model Category {
  id                    BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  name                  String              @db.VarChar(255)
  slug                  String              @unique(map: "categories_slug_unique") @db.VarChar(255)
  title                 String?             @db.VarChar(255)
  description           String?             @db.VarChar(255)
  regular_buyer_fee     Float?              @default(0)
  extended_buyer_fee    Float?              @default(0)
  file_type             Boolean?
  thumbnail_width       BigInt              @default(120) @db.UnsignedBigInt
  thumbnail_height      BigInt              @default(120) @db.UnsignedBigInt
  preview_image_width   BigInt?             @db.UnsignedBigInt
  preview_image_height  BigInt?             @db.UnsignedBigInt
  maximum_screenshots   BigInt?             @db.UnsignedBigInt
  main_file_types       String              @default("zip,rar,pdf") @db.VarChar(255)
  max_preview_file_size BigInt              @default(10485760) @db.UnsignedBigInt
  views                 BigInt              @default(0)
  sort_id               BigInt              @default(0)
  created_at            DateTime?           @db.Timestamp(0)
  updated_at            DateTime?           @db.Timestamp(0)
  category_options      category_options[]
  category_reviewer     category_reviewer[]
  item_updates          item_updates[]
  items                 items[]
  sub_categories        sub_categories[]
  uploaded_files        uploaded_files[]

  @@map("categories")
}

model CartItem {
  id                BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  session_id        String?          @db.VarChar(255)
  userId            BigInt?          @map("user_id") @db.UnsignedBigInt
  item_id           BigInt           @db.UnsignedBigInt
  licenseType       Int              @default(1) @map("license_type") @db.TinyInt
  quantity          Int              @default(1) @db.UnsignedInt
  support_period_id BigInt?          @db.UnsignedBigInt
  created_at        DateTime?        @db.Timestamp(0)
  updated_at        DateTime?        @db.Timestamp(0)
  items             items            @relation(fields: [item_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "cart_items_item_id_foreign")
  support_periods   support_periods? @relation(fields: [support_period_id], references: [id], onUpdate: Restrict, map: "cart_items_support_period_id_foreign")
  user              User?            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "cart_items_user_id_foreign")

  @@index([item_id], map: "cart_items_item_id_foreign")
  @@index([support_period_id], map: "cart_items_support_period_id_foreign")
  @@index([userId], map: "cart_items_user_id_foreign")
  @@map("cart_items")
}

