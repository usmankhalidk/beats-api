NODE_ENV=development
PORT=4000
APP_NAME=beats-api
APP_URL=http://localhost:4000

DATABASE_URL="mysql://root:password@localhost:3306/beats_dev"

JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PASSWORD_RESET_TOKEN_TTL_MINUTES=30

CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

LOG_LEVEL=info

# Contabo S3-compatible object storage
CONTABO_ENDPOINT=https://eu2.contabostorage.com
CONTABO_ACCESS_ID=replace-with-contabo-client-id
CONTABO_ACCESS_KEY=replace-with-contabo-client-secret
CONTABO_AVATAR_BUCKET_NAME=profile.avatars
CONTABO_AVATAR_BASE_URL=your_bucket_url
BEAT_BUCKET_NAME=beats