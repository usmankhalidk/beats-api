NODE_ENV=development
PORT=4000
APP_NAME=beats-api
APP_URL=http://localhost:4000

DATABASE_URL="mysql://root:password@localhost:3306/beats_dev"

JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PASSWORD_RESET_TOKEN_TTL_MINUTES=30

CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

LOG_LEVEL=info

# Contabo S3-compatible object storage
CONTABO_ENDPOINT=https://eu2.contabostorage.com
CONTABO_ACCESS_ID=replace-with-contabo-client-id
CONTABO_ACCESS_KEY=replace-with-contabo-client-secret
CONTABO_AVATAR_BUCKET_NAME=profile.avatars
CONTABO_AVATAR_BASE_URL=your_bucket_url
BEAT_BUCKET_NAME=beats

# SMTP
MAIL_HOST=mail.yourdomain.com
MAIL_PORT=465
MAIL_USER=mail@yourdomain.com
MAIL_PASS=replace-with-smtp-password
MAIL_FROM=Beatpillz <mail@yourdomain.com>
FRONTEND_URL=http://localhost:3000
EMAIL_VERIFICATION_TTL_MINUTES=1440

# ── OAuth: Google Sign-In ──────────────────────────────────
# OAuth 2.0 Client ID(s) from Google Cloud Console → APIs & Services → Credentials.
# The frontend obtains a Google ID token and POSTs it to /api/v1/auth/google; the
# API verifies it against these audiences. List multiple (web, iOS, Android) comma-
# separated. Leave empty to disable Google Sign-In. No client secret is required.
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com

# ── Payments ───────────────────────────────────────────────
# Settlement currency is always NGN. USD/EUR/GBP/JPY/CNY/NGN are display currencies
# the buyer browses/checks out in; the gateway is always charged in NGN, converted
# from the base (USD) price via the `currencies` table rate.
#
# Payment confirmation is webhook-only — register the webhook URL in each gateway
# dashboard: {APP_URL}/api/v1/webhooks/{paystack|flutterwave|opay}
# PAYMENT_CALLBACK_URL is only the buyer's post-payment redirect (a deep link or
# return page the app intercepts to start polling GET /checkout/{id}/status). It is
# NOT processed server-side and plays no part in confirming payment.
PAYMENT_CALLBACK_URL=http://localhost:3000/payment/return
PAYMENT_BASE_CURRENCY=USD

# Currency seed rates (units per 1 USD). Optional — override the seed defaults.
# Keep these current from a live FX source; NGN is the settlement rate.
# SEED_EUR_RATE=0.92
# SEED_GBP_RATE=0.79
# SEED_JPY_RATE=157
# SEED_CNY_RATE=7.2
# SEED_NGN_RATE=1600

# Paystack
PAYSTACK_SECRET_KEY=sk_test_replace-me
PAYSTACK_PUBLIC_KEY=pk_test_replace-me

# Flutterwave
FLW_SECRET_KEY=FLWSECK_TEST-replace-me
FLW_PUBLIC_KEY=FLWPUBK_TEST-replace-me
FLW_WEBHOOK_HASH=replace-with-a-strong-secret
FLW_GOOGLE_PAY_ENABLED=false

# OPay
OPAY_MERCHANT_ID=replace-with-merchant-id
OPAY_PUBLIC_KEY=replace-with-opay-public-key
OPAY_SECRET_KEY=replace-with-opay-secret-key
OPAY_BASE_URL=https://sandboxapi.opaycheckout.com